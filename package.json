{
  "name": "when-hooks",
  "private": true,
  "description": "条件生命周期钩子库",
  "author": "DBAAZzz",
  "license": "ISC",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "build": "pnpm -r run build",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "pnpm -r exec tsc --noEmit",
    "check-publish": "pnpm -r exec publint",
    "release": "pnpm typecheck && pnpm test:run && pnpm build && pnpm check-publish && pnpm -r publish --access public",
    "release:dry": "pnpm build && pnpm -r publish --dry-run --no-git-checks"
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "publint": "^0.2.12",
    "typescript": "^5.6.3",
    "unbuild": "^3.0.1",
    "vitest": "^2.1.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DBAAZzz/when-hooks.git"
  }
}
